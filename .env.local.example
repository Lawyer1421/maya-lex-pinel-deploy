# ===================================================
# MAYA LEX IA PINEL HN — Variables de Entorno
# Copiar este archivo como .env.local y completar valores
# NUNCA subir .env.local a GitHub
# ===================================================

# --- ANTHROPIC / CLAUDE API ---
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- SUPABASE ---
# Obtener en: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX

# --- RATE LIMITING ---
# Consultas por día en el plan gratuito
FREE_TIER_DAILY_LIMIT=3
# Consultas por día en el plan Pro
PRO_TIER_DAILY_LIMIT=100

# --- STRIPE (pagos) ---
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Precio mensual Plan Pro (ID de precio en Stripe)
STRIPE_PRO_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXXXX

# --- CONFIGURACIÓN APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: https://maya-lex.vercel.app

# --- RAG — BIBLIOTECA PENAL PINEL ---
# Backend de búsqueda semántica del CPP/CP.
# Opciones:
#   disabled → sin RAG (solo system prompt + normas-cpp.ts)
#   python   → microservicio FastAPI local (python-rag/api_fastapi.py)
#   supabase → Supabase pgvector (producción, requiere tabla biblioteca_penal)
RAG_BACKEND=disabled

# URL del microservicio Python RAG (solo si RAG_BACKEND=python)
# Arrancar con: cd python-rag && uvicorn api_fastapi:app --port 8100
PYTHON_RAG_URL=http://localhost:8100

# --- MODO DEBUG ---
# true = mostrar logs de Claude en consola
DEBUG_CLAUDE=false
