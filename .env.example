# ══════════════════════════════════════════════════════════════
# Maya Lex IA — Variables de entorno (plantilla)
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA comitas .env.local al repositorio.
# ══════════════════════════════════════════════════════════════

# ── IA Principal ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenRouter (multimodel — opcional) ────────────────────────
OPENROUTER_API_KEY=
# 'anthropic' (default) | 'openrouter' (experimental)
LLM_PROVIDER=anthropic

# ── Búsqueda web (Tavily) ──────────────────────────────────────
# Obtener en: https://app.tavily.com → API Keys
# Si vacío: webSearch usa fallback a RAG local
TAVILY_API_KEY=

# ── RAG Backend ────────────────────────────────────────────────
# 'disabled' | 'python' (FastAPI local) | 'supabase'
RAG_BACKEND=python
PYTHON_RAG_URL=http://localhost:8100

# ── Supabase (base de datos + analytics + auth) ────────────────
# Obtener en: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase PostgreSQL — requerido para npm run migrate:analytics
# Obtener en: Supabase Dashboard → Settings → Database → URI
# Formato: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=

# ── PayPal (Subscriptions API) ────────────────────────────────
# Docs: https://developer.paypal.com/dashboard/ → My Apps & Credentials
# 'sandbox' | 'live'
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_PRO_PLAN_ID=
PAYPAL_ACADEMICO_PLAN_ID=
PAYPAL_WEBHOOK_ID=
# DEV ONLY: NUNCA true en producción (PAYPAL_MODE=live)
PAYPAL_DEV_BYPASS_VERIFY=false

# ── General ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEBUG_CLAUDE=false

# ── Rate Limiting ──────────────────────────────────────────────
FREE_TIER_DAILY_LIMIT=3
PRO_TIER_DAILY_LIMIT=100
